<Window x:Class="MandatoryReminder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Battery Charge Reminder"
        Width="1060"
        Height="700"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        FontFamily="Segoe UI"
        Background="#FFF3F3F3">
    <Window.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#FFDADADA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF222222" />
        </Style>

        <Style x:Key="MetaStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#FF666666" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}" />

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="30" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Foreground" Value="#FF222222" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel>
            <StackPanel DockPanel.Dock="Left">
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#FF1F1F1F"
                           Text="Battery Charge Reminder" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#FF666666"
                           Text="Monitor battery status, manage reminder thresholds, and review recent battery events." />
            </StackPanel>

            <Border DockPanel.Dock="Right"
                    Padding="12,6"
                    Background="#FFF7F7F7"
                    BorderBrush="#FFD8D8D8"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock x:Name="HeaderStatusTextBlock"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#FF2D5A88"
                           Text="Tray monitoring active" />
            </Border>
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.65*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.25*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="0.95*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Border x:Name="StatusBadgeBorder"
                                    HorizontalAlignment="Left"
                                    Padding="10,4"
                                    Background="#FFEFF4F8"
                                    BorderBrush="#FFD6E3EE"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <TextBlock x:Name="StatusBadgeTextBlock"
                                           FontWeight="SemiBold"
                                           Foreground="#FF264B6B"
                                           Text="Starting up" />
                            </Border>

                            <TextBlock x:Name="CurrentPercentTextBlock"
                                       Margin="0,18,0,0"
                                       FontSize="58"
                                       FontWeight="SemiBold"
                                       Foreground="#FF202020"
                                       Text="0%" />

                            <TextBlock x:Name="CurrentStatusTextBlock"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#FF2C2C2C"
                                       Text="Waiting for battery data..." />

                            <TextBlock x:Name="CurrentDetailsTextBlock"
                                       Margin="0,10,0,0"
                                       Width="420"
                                       Foreground="#FF666666"
                                       TextWrapping="Wrap"
                                       Text="The tray app is starting battery monitoring now." />
                        </StackPanel>

                        <Border Grid.Column="2"
                                Style="{StaticResource PanelStyle}"
                                Padding="14"
                                Background="#FFFAFAFA">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetaStyle}"
                                           Text="CURRENT STATUS" />
                                <ProgressBar x:Name="ChargeProgressBar"
                                             Margin="0,14,0,12"
                                             Height="16"
                                             Maximum="100"
                                             Value="0" />
                                <TextBlock x:Name="PowerSourceValueTextBlock"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#FF2C2C2C"
                                           Text="Waiting" />
                                <TextBlock x:Name="LastCheckedTextBlock"
                                           Margin="0,8,0,0"
                                           Foreground="#FF666666"
                                           Text="Last checked: -" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetaStyle}"
                                       Text="NEXT ALERT" />
                            <TextBlock x:Name="NextReminderValueTextBlock"
                                       Margin="0,8,0,4"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#FF2C2C2C"
                                       Text="Calculating" />
                            <TextBlock Foreground="#FF666666"
                                       Text="The next armed threshold is shown here." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetaStyle}"
                                       Text="DELIVERY" />
                            <TextBlock x:Name="DeliveryValueTextBlock"
                                       Margin="0,8,0,4"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#FF2C2C2C"
                                       Text="Popup + Tray" />
                            <TextBlock Foreground="#FF666666"
                                       Text="How notifications will be shown." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MetaStyle}"
                                       Text="QUICK ACTIONS" />
                            <WrapPanel Margin="0,10,0,0">
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Click="RefreshNowButton_Click"
                                        Content="Refresh" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Click="TestReminderButton_Click"
                                        Content="Preview" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,10,0,0"
                                        Click="HideToTrayButton_Click"
                                        Content="Hide To Tray" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="4"
                        Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="Battery History" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#FF666666"
                                           Text="Recent battery changes and reminder events." />
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    MinWidth="100"
                                    Padding="12,6"
                                    Click="ClearHistoryButton_Click"
                                    Content="Clear History" />
                        </DockPanel>

                        <Grid Grid.Row="2">
                            <DataGrid x:Name="HistoryDataGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="Horizontal"
                                      Background="White">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Timestamp, StringFormat=g}" Header="Timestamp" Width="170" />
                                    <DataGridTextColumn Binding="{Binding ChargePercent, StringFormat={}{0}%}" Header="Charge" Width="90" />
                                    <DataGridTextColumn Binding="{Binding PowerState}" Header="Power State" Width="160" />
                                    <DataGridTextColumn Binding="{Binding EventType}" Header="Type" Width="110" />
                                    <DataGridTextColumn Binding="{Binding Message}" Header="Message" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock x:Name="EmptyHistoryTextBlock"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       Foreground="#FF888888"
                                       IsHitTestVisible="False"
                                       Text="No battery history yet. Let the monitor run or preview a reminder to populate this list." />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Charge Targets" />
                        <TextBlock Margin="0,6,0,16"
                                   Foreground="#FF666666"
                                   Text="Choose the levels that should trigger reminders." />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="86" />
                                <ColumnDefinition Width="24" />
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="HighReminderCheckBox"
                                      Content="Notify when charging reaches" />
                            <TextBox x:Name="HighReminderTextBox"
                                     Grid.Column="1"
                                     Margin="10,0,0,0" />
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Foreground="#FF666666"
                                       Text="%" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="86" />
                                <ColumnDefinition Width="24" />
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="LowReminderCheckBox"
                                      Content="Notify when battery falls to" />
                            <TextBox x:Name="LowReminderTextBox"
                                     Grid.Column="1"
                                     Margin="10,0,0,0" />
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Foreground="#FF666666"
                                       Text="%" />
                        </Grid>

                        <CheckBox x:Name="FullReminderCheckBox"
                                  Content="Also notify when the battery reaches 100%" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource PanelStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Reminder Delivery" />
                        <TextBlock Margin="0,6,0,16"
                                   Foreground="#FF666666"
                                   Text="Choose how battery reminders should be shown." />
                        <CheckBox x:Name="ForcePopupCheckBox"
                                  Content="Show an always-on-top reminder window" />
                        <CheckBox x:Name="PlaySoundCheckBox"
                                  Content="Play a sound when an alert appears" />
                        <CheckBox x:Name="TrayNotificationCheckBox"
                                  Content="Show a tray balloon notification" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Style="{StaticResource PanelStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Automation" />
                        <TextBlock Margin="0,6,0,16"
                                   Foreground="#FF666666"
                                   Text="Keep the app ready in the background." />
                        <CheckBox x:Name="RunOnStartupCheckBox"
                                  Content="Launch automatically when Windows starts" />

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Style="{StaticResource MetaStyle}"
                                           Text="CHECK INTERVAL" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#FF666666"
                                           Text="How often the tray app samples battery status." />
                            </StackPanel>

                            <TextBox x:Name="MonitorIntervalTextBox"
                                     Grid.Column="1"
                                     Margin="12,0,0,0" />
                        </Grid>

                        <TextBlock Margin="0,0,0,14"
                                   Foreground="#FF666666"
                                   TextWrapping="Wrap"
                                   Text="Tip: keep popup and sound enabled for low battery, and use tray notifications for gentler charging reminders." />

                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0"
                                Click="SaveSettingsButton_Click"
                                Content="Save Settings" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
