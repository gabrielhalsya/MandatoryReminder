<Window x:Class="MandatoryReminder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Battery Charge Reminder"
        Width="1240"
        Height="840"
        MinWidth="1040"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        FontFamily="Segoe UI Variable Display"
        Background="#FF081319">
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF081319" Offset="0" />
            <GradientStop Color="#FF10232A" Offset="0.55" />
            <GradientStop Color="#FF0B151B" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#66B6FFF2" Offset="0" />
            <GradientStop Color="#66FFD8A8" Offset="0.45" />
            <GradientStop Color="#667DB7FF" Offset="1" />
        </LinearGradientBrush>
        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="BorderBrush" Value="#2DFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="26" />
            <Setter Property="Padding" Value="22" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FFF5FBFF" />
        </Style>
        <Style x:Key="MetaStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#9FD8E9EF" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FF041116" />
            <Setter Property="Background" Value="#FFF2FBFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#FFF2FBFF" />
            <Setter Property="Background" Value="#1FFFFFFF" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="Foreground" Value="#FFF6FBFF" />
            <Setter Property="BorderBrush" Value="#2BFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="11,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Foreground" Value="#FFF1F8FC" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#06FFFFFF" />
            <Setter Property="Foreground" Value="#FFF4FBFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#14FFFFFF" />
            <Setter Property="VerticalGridLinesBrush" Value="#00FFFFFF" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="#00FFFFFF" />
            <Setter Property="AlternatingRowBackground" Value="#08FFFFFF" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#16FFFFFF" />
            <Setter Property="Foreground" Value="#FFD6E8EF" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFF4FBFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,11" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowGradient}">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="420" Height="420" Fill="#12FFFFFF" Canvas.Left="-120" Canvas.Top="-90" />
            <Ellipse Width="280" Height="280" Fill="#14B9FFF5" Canvas.Left="900" Canvas.Top="56" />
            <Ellipse Width="240" Height="240" Fill="#12FFC999" Canvas.Left="1030" Canvas.Top="520" />
        </Canvas>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource MetaStyle}"
                                   Text="LIGHTWEIGHT GLASS DASHBOARD" />
                        <TextBlock Margin="0,8,0,6"
                                   FontSize="35"
                                   FontWeight="SemiBold"
                                   Foreground="#FFF7FCFF"
                                   Text="Battery Charge Reminder" />
                        <TextBlock Width="720"
                                   FontSize="15"
                                   Foreground="#B7D8E9EF"
                                   TextWrapping="Wrap"
                                   Text="Modern tray-first battery monitoring with clear status, quicker actions, and softer glass panels that stay light enough for everyday desktop use." />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="16,8"
                            Background="#18FFFFFF"
                            BorderBrush="#2DFFFFFF"
                            BorderThickness="1"
                            CornerRadius="999">
                        <TextBlock x:Name="HeaderStatusTextBlock"
                                   Foreground="#FFF5FBFF"
                                   FontWeight="SemiBold"
                                   Text="Tray monitoring active" />
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.72*" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="1.02*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource GlassCardStyle}"
                                Background="#1AFFFFFF">
                            <Grid>
                                <Rectangle RadiusX="26"
                                           RadiusY="26"
                                           Fill="{StaticResource HeroGradient}"
                                           Opacity="0.8" />

                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="0.92*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <Border x:Name="StatusBadgeBorder"
                                                HorizontalAlignment="Left"
                                                Padding="14,7"
                                                Background="#D8EAF3F1"
                                                CornerRadius="999">
                                            <TextBlock x:Name="StatusBadgeTextBlock"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF18333A"
                                                       Text="Starting up" />
                                        </Border>

                                        <TextBlock x:Name="CurrentPercentTextBlock"
                                                   Margin="0,18,0,0"
                                                   FontSize="86"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFF8FCFF"
                                                   Text="0%" />
                                        <TextBlock x:Name="CurrentStatusTextBlock"
                                                   FontSize="28"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFF7FCFF"
                                                   Text="Waiting for battery data..." />
                                        <TextBlock x:Name="CurrentDetailsTextBlock"
                                                   Width="430"
                                                   Margin="0,10,0,0"
                                                   FontSize="15"
                                                   Foreground="#D8EFF7FB"
                                                   TextWrapping="Wrap"
                                                   Text="The tray app is starting battery monitoring now." />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Background="#1C081319"
                                            BorderBrush="#2BFFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="24"
                                            Padding="18">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetaStyle}"
                                                       Foreground="#BFE6F6FC"
                                                       Text="LIVE CHARGE" />
                                            <ProgressBar x:Name="ChargeProgressBar"
                                                         Margin="0,18,0,12"
                                                         Height="16"
                                                         Maximum="100"
                                                         Background="#20FFFFFF"
                                                         Foreground="#FFF2FBFF"
                                                         Value="0" />
                                            <TextBlock x:Name="PowerSourceValueTextBlock"
                                                       FontSize="25"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFF7FCFF"
                                                       Text="Waiting" />
                                            <TextBlock x:Name="LastCheckedTextBlock"
                                                       Margin="0,8,0,0"
                                                       Foreground="#C9E2EEF3"
                                                       Text="Last checked: -" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource GlassCardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetaStyle}"
                                               Text="NEXT ALERT" />
                                    <TextBlock x:Name="NextReminderValueTextBlock"
                                               Margin="0,10,0,6"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#FFF7FCFF"
                                               Text="Calculating" />
                                    <TextBlock Foreground="#B7D8E9EF"
                                               Text="The next armed threshold stays visible here." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource GlassCardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetaStyle}"
                                               Text="DELIVERY" />
                                    <TextBlock x:Name="DeliveryValueTextBlock"
                                               Margin="0,10,0,6"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#FFF7FCFF"
                                               Text="Popup + Tray" />
                                    <TextBlock Foreground="#B7D8E9EF"
                                               Text="See how alerts will reach you right now." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4"
                                    Style="{StaticResource GlassCardStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetaStyle}"
                                               Text="QUICK ACTIONS" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                                Click="RefreshNowButton_Click"
                                                Content="Refresh" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Click="TestReminderButton_Click"
                                                Content="Preview" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0,12,0,0"
                                                Click="HideToTrayButton_Click"
                                                Content="Hide To Tray" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4"
                                Style="{StaticResource GlassCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                                   Text="Battery History" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="#B7D8E9EF"
                                                   Text="A clean timeline of charge changes and reminder events." />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0"
                                            Click="ClearHistoryButton_Click"
                                            Content="Clear History" />
                                </DockPanel>

                                <Grid Grid.Row="2">
                                    <DataGrid x:Name="HistoryDataGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              HeadersVisibility="Column"
                                              IsReadOnly="True"
                                              RowHeaderWidth="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Binding="{Binding Timestamp, StringFormat=g}" Header="Timestamp" Width="170" />
                                            <DataGridTextColumn Binding="{Binding ChargePercent, StringFormat={}{0}%}" Header="Charge" Width="90" />
                                            <DataGridTextColumn Binding="{Binding PowerState}" Header="Power State" Width="160" />
                                            <DataGridTextColumn Binding="{Binding EventType}" Header="Type" Width="110" />
                                            <DataGridTextColumn Binding="{Binding Message}" Header="Message" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <TextBlock x:Name="EmptyHistoryTextBlock"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="17"
                                               Foreground="#97C7D9E0"
                                               IsHitTestVisible="False"
                                               Text="No battery history yet. Let the monitor run or preview a reminder to populate this timeline." />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource GlassCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="Charge Targets" />
                                <TextBlock Margin="0,8,0,18"
                                           Foreground="#B7D8E9EF"
                                           Text="Choose the battery levels that matter most." />

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="24" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="HighReminderCheckBox"
                                              Content="Notify when charging reaches" />
                                    <TextBox x:Name="HighReminderTextBox"
                                             Grid.Column="1"
                                             Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               VerticalAlignment="Center"
                                               Foreground="#B7D8E9EF"
                                               Text="%" />
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="24" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="LowReminderCheckBox"
                                              Content="Notify when battery falls to" />
                                    <TextBox x:Name="LowReminderTextBox"
                                             Grid.Column="1"
                                             Margin="10,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               VerticalAlignment="Center"
                                               Foreground="#B7D8E9EF"
                                               Text="%" />
                                </Grid>

                                <CheckBox x:Name="FullReminderCheckBox"
                                          Content="Also notify when the battery reaches 100%" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource GlassCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="Reminder Delivery" />
                                <TextBlock Margin="0,8,0,18"
                                           Foreground="#B7D8E9EF"
                                           Text="Blend urgency and calm depending on what kind of reminder you want." />
                                <CheckBox x:Name="ForcePopupCheckBox"
                                          Content="Show an always-on-top reminder window" />
                                <CheckBox x:Name="PlaySoundCheckBox"
                                          Content="Play a sound when an alert appears" />
                                <CheckBox x:Name="TrayNotificationCheckBox"
                                          Content="Show a tray balloon notification" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4"
                                Style="{StaticResource GlassCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="Automation" />
                                <TextBlock Margin="0,8,0,18"
                                           Foreground="#B7D8E9EF"
                                           Text="Keep the app quietly ready in the background." />
                                <CheckBox x:Name="RunOnStartupCheckBox"
                                          Content="Launch automatically when Windows starts" />

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetaStyle}"
                                                   Text="CHECK INTERVAL" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#B7D8E9EF"
                                                   Text="How often the tray app samples battery status." />
                                    </StackPanel>
                                    <TextBox x:Name="MonitorIntervalTextBox"
                                             Grid.Column="1"
                                             Margin="12,0,0,0" />
                                </Grid>

                                <Border Background="#12FFFFFF"
                                        BorderBrush="#24FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="14"
                                        Margin="0,0,0,18">
                                    <TextBlock Foreground="#C5E2EEF3"
                                               Text="Tip: combine popup and sound for low battery, then keep tray notifications enabled for gentler charging alerts." />
                                </Border>

                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0"
                                        Click="SaveSettingsButton_Click"
                                        Content="Save Settings" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
