<Window x:Class="MandatoryReminder.MandatoryPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Battery Alert"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Segoe UI Variable Display"
        Background="#00000000"
        AllowsTransparency="True">
    <Grid>
        <Border Margin="18"
                CornerRadius="30"
                Background="#E61A242B"
                BorderBrush="#2EFFFFFF"
                BorderThickness="1">
            <Grid>
                <Rectangle RadiusX="30"
                           RadiusY="30"
                           Fill="#12FFFFFF" />

                <Grid Margin="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="SidebarBorder"
                                Width="118"
                                Height="118"
                                CornerRadius="22"
                                Background="#FF174D59">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#BFF3FBFF"
                                           Text="ALERT" />
                                <TextBlock x:Name="PopupPercentTextBlock"
                                           Margin="0,8,0,0"
                                           FontSize="42"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="0%" />
                                <TextBlock x:Name="PopupStateTextBlock"
                                           Margin="0,2,0,0"
                                           FontSize="14"
                                           Foreground="#D8F0FBFF"
                                           Text="Waiting" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#94D2E7EF"
                                       Text="BATTERY REMINDER" />
                            <TextBlock x:Name="ReminderTitleTextBlock"
                                       Margin="0,8,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#FFF6FBFF"
                                       Text="Reminder" />
                            <TextBlock x:Name="ReminderMessageTextBlock"
                                       Margin="0,10,0,0"
                                       FontSize="15"
                                       Foreground="#C6E4EEF3"
                                       TextWrapping="Wrap"
                                       Text="Your battery reminder message will appear here." />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2"
                            Padding="14"
                            Background="#12FFFFFF"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="ReminderSnapshotTextBlock"
                                       Foreground="#DFF5FBFF"
                                       FontWeight="SemiBold"
                                       Text="0% | Waiting | -" />

                            <WrapPanel Grid.Row="2">
                                <Button Padding="16,10"
                                        Margin="0,0,12,0"
                                        Background="#FFF2FBFF"
                                        BorderThickness="0"
                                        Foreground="#FF081319"
                                        FontWeight="SemiBold"
                                        Click="OpenDashboardButton_Click"
                                        Content="Open Dashboard" />
                                <Button Padding="16,10"
                                        Background="#18FFFFFF"
                                        BorderBrush="#24FFFFFF"
                                        BorderThickness="1"
                                        Foreground="#FFF4FBFF"
                                        FontWeight="SemiBold"
                                        Click="DismissButton_Click"
                                        Content="Dismiss" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
