<Window x:Class="MandatoryReminder.MandatoryPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Battery Alert"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Segoe UI"
        Background="#FFF4F4F4">
    <Grid Margin="16">
        <Border Background="White"
                BorderBrush="#FFDADADA"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="SidebarBorder"
                        Width="110"
                        Height="110"
                        Background="#FF2D5A88"
                        CornerRadius="6">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="ALERT" />
                        <TextBlock x:Name="PopupPercentTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="38"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="0%" />
                        <TextBlock x:Name="PopupStateTextBlock"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="#FFEAF2F9"
                                   Text="Waiting" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2">
                    <TextBlock FontSize="12"
                               Foreground="#FF666666"
                               Text="BATTERY REMINDER" />
                    <TextBlock x:Name="ReminderTitleTextBlock"
                               Margin="0,8,0,0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#FF222222"
                               Text="Reminder" />
                    <TextBlock x:Name="ReminderMessageTextBlock"
                               Margin="0,10,0,0"
                               Foreground="#FF666666"
                               TextWrapping="Wrap"
                               Text="Your battery reminder message will appear here." />
                </StackPanel>

                <Border Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Padding="12"
                        Background="#FFF7F7F7"
                        BorderBrush="#FFDADADA"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="ReminderSnapshotTextBlock"
                                   FontWeight="SemiBold"
                                   Foreground="#FF444444"
                                   Text="0% | Waiting | -" />

                        <WrapPanel Grid.Row="2">
                            <Button Padding="14,7"
                                    Margin="0,0,10,0"
                                    Click="OpenDashboardButton_Click"
                                    Content="Open Dashboard" />
                            <Button Padding="14,7"
                                    Click="DismissButton_Click"
                                    Content="Dismiss" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
